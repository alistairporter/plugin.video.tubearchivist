<settings>
    <category label="Connection">
        <setting id="server_url"
                 type="text"
                 label="Tube Archivist Server URL"
                 default="http://localhost:8000" />
        <setting id="api_token"
                 type="text"
                 label="API Token"
                 option="hidden" />
    </category>

    <category label="Sorting">
        <setting id="sort_order"
                 type="enum"
                 label="Video Sort Order"
                 values="Newest First|Oldest First|Alphabetical A-Z|Alphabetical Z-A"
                 default="0" />
        <setting id="max_videos"
                 type="number"
                 label="Max videos to load"
                 default="50"
                 range="10,500"
                 step="25" />
    </category>

    <category label="SponsorBlock">
        <setting id="sponsorblock_enabled"
                 type="bool"
                 label="Enable SponsorBlock"
                 default="true" />
        <setting id="sponsorblock_auto_skip"
                 type="bool"
                 label="Automatically skip segments"
                 default="true"
                 enable="eq(-1,true)" />
        <setting id="sponsorblock_show_notifications"
                 type="bool"
                 label="Show notifications"
                 default="true"
                 enable="eq(-2,true)" />

        <setting type="sep" />
        <setting id="sponsorblock_sponsor"
                 type="enum"
                 label="Sponsor segments"
                 values="Skip|Mute|Nothing"
                 default="0"
                 enable="eq(-3,true)" />
        <setting id="sponsorblock_intro"
                 type="enum"
                 label="Intro segments"
                 values="Skip|Mute|Nothing"
                 default="0"
                 enable="eq(-4,true)" />
        <setting id="sponsorblock_outro"
                 type="enum"
                 label="Outro segments"
                 values="Skip|Mute|Nothing"
                 default="2"
                 enable="eq(-5,true)" />
        <setting id="sponsorblock_selfpromo"
                 type="enum"
                 label="Self-promotion segments"
                 values="Skip|Mute|Nothing"
                 default="2"
                 enable="eq(-6,true)" />
        <setting id="sponsorblock_interaction"
                 type="enum"
                 label="Interaction reminder segments"
                 values="Skip|Mute|Nothing"
                 default="2"
                 enable="eq(-7,true)" />
        <setting id="sponsorblock_music_offtopic"
                 type="enum"
                 label="Music/Off-topic segments"
                 values="Skip|Mute|Nothing"
                 default="2"
                 enable="eq(-8,true)" />
        <setting id="sponsorblock_preview"
                 type="enum"
                 label="Preview/Recap segments"
                 values="Skip|Mute|Nothing"
                 default="2"
                 enable="eq(-9,true)" />
        <setting id="sponsorblock_filler"
                 type="enum"
                 label="Filler tangent segments"
                 values="Skip|Mute|Nothing"
                 default="2"
                 enable="eq(-10,true)" />
    </category>
</settings>
